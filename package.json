{
  "name": "saucedemo-automation-framework",
  "version": "1.0.0",
  "description": "Framework de automatización profesional para SauceDemo con Playwright + TypeScript (funcional, SEO, accesibilidad y performance).",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:functional": "playwright test --project=functional",
    "test:seo": "playwright test --project=seo",
    "test:a11y": "playwright test --project=accessibility",
    "test:performance": "playwright test --project=performance",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "demo:a11y": "playwright test --project=accessibility --headed --workers=1",
    "demo:func": "playwright test --project=functional --headed --workers=1",
    "demo:seo": "playwright test --project=seo --headed --workers=1",
    "demo:perf": "playwright test --project=performance --headed --workers=1",
    "demo:all": "npm run demo:a11y && npm run demo:func && npm run demo:seo && npm run demo:perf",
    "report:html": "playwright show-report",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:serve": "allure serve reports/allure-results",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.16.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^2.0.0",
    "globals": "^15.11.0",
    "playwright-lighthouse": "^4.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.11.0"
  }
}
